{
  "expo": {
    "name": "Locksy",
    "slug": "locksy",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "locksy",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,

    "icon": "./assets/logo.png",

    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.locksy.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Locksy to access your camera for QR scanning and video calls.",
        "NSMicrophoneUsageDescription": "Allow Locksy to access your microphone for audio and video calls.",
        "NSPhotoLibraryUsageDescription": "Allow Locksy to access your photos.",
        "NSUserTrackingUsageDescription": "This app uses notifications and connectivity features."
      },
      "bitcode": false
    },

    "android": {
      "package": "com.innosphere.locksy",
      "versionCode": 1,

      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true,

      "googleServicesFile": "./google-services.json",

      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.BLUETOOTH"
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "./plugins/withAndroidBuildTypeFix",

      "expo-secure-store",

      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],

      [
        "expo-camera",
        {
          "cameraPermission": "Allow Locksy to access your camera to scan QR codes and make video calls."
        }
      ],

      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Locksy to access your photos and media."
        }
      ],

      "expo-av",

      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Locksy to access your camera for video calls.",
          "microphonePermission": "Allow Locksy to access your microphone for audio calls."
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "da18476e-4821-4c94-acb7-1902ff79c0e3"
      },
      "apiUrl": "https://locksy.info"
    },

    "runtimeVersion": {
      "policy": "sdkVersion"
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "owner": "badobadiapp"
  }
}
